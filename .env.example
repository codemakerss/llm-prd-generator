# Host-model skill mode only needs WIKI_* values.
# LLM_* values are only required for standalone OpenAI-compatible CLI/API mode.
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your_api_key
LLM_MODEL=gpt-4.1-mini
LLM_TIMEOUT=60
WIKI_ROOT=./runtime/vault
WIKI_INDEX_DB=./runtime/vault/index.sqlite3
WIKI_LAYOUT_LANGUAGE=en
WIKI_SCOPE=stable
